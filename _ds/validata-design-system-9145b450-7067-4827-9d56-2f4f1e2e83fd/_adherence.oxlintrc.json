{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "dashboard/**",
              "ui_kits/app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {},
    "tokens": [
      "--bg",
      "--border",
      "--border-soft",
      "--chip-amber-bg",
      "--chip-amber-fg",
      "--chip-blue-bg",
      "--chip-blue-fg",
      "--chip-orange-bg",
      "--chip-orange-fg",
      "--container-max",
      "--critical",
      "--danger",
      "--danger-bg",
      "--font-body",
      "--font-display",
      "--font-mono",
      "--gold",
      "--good",
      "--gutter",
      "--info",
      "--info-bg",
      "--ink",
      "--muted",
      "--navy",
      "--navy-2",
      "--norev",
      "--orange",
      "--orange-deep",
      "--orange-hover",
      "--orange-press",
      "--r-lg",
      "--r-md",
      "--r-pill",
      "--r-sm",
      "--radius",
      "--ring-focus",
      "--row-alt",
      "--shadow-card",
      "--shadow-hover",
      "--shadow-pop",
      "--shadow-stat",
      "--sidebar-w",
      "--stack-lg",
      "--stack-md",
      "--stack-sm",
      "--success",
      "--success-bg",
      "--surface",
      "--surface-alt",
      "--text",
      "--text-muted",
      "--text-on-dark",
      "--text-on-dark-dim",
      "--text-on-dark-faint",
      "--text-secondary",
      "--topbar-h",
      "--warning",
      "--warning-bg",
      "--white"
    ],
    "tokenKinds": {
